        "caption": {
          "type": "caption",
          "settings": {
            "caption": "Our Story",
            "text_style": "subtitle"
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Born in Atlanta. Built for the Bold.",
            "heading_size": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "Vain Shades was created for those who don't follow fashion — they set it. Our statement sunglasses are designed to command attention, crafted for the glamorous, the unapologetic, and the bold. Based in Atlanta, available worldwide."
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Our Full Story",
            "button_link": "shopify://pages/about-us",
            "button_style_secondary": false
          }
        }
      },
      "block_order": [
        "caption",
        "heading",
        "text",
        "button"
      ],
      "settings": {
        "height": "adapt",
        "desktop_image_width": "medium",
        "layout": "image_first",
        "desktop_content_position": "middle",
        "desktop_content_alignment": "left",
        "content_layout": "no-overlap",
        "color_scheme": "scheme-1",
        "mobile_content_alignment": "left",
        "padding_top": 72,
        "padding_bottom": 72
      }
    },
    "instagram_showcase": {
      "type": "multicolumn",
      "blocks": {
        "col1": {
          "type": "column",
          "settings": {
            "title": "Day Dreamer",
            "text": "The oversized silhouette that turns heads at any Atlanta rooftop.",
            "link_label": "Shop Style",
            "link": "shopify://collections/home-page"
          }
        },
        "col2": {
          "type": "column",
          "settings": {
            "title": "Soho",
            "text": "Sharp edges, bold lenses. Street-ready luxury from the A.",
            "link_label": "Shop Style",
            "link": "shopify://collections/all"
          }
        },
        "col3": {
          "type": "column",
          "settings": {
            "title": "Super Cats",
            "text": "The cat-eye reimagined. Unapologetically feminine, fiercely editorial.",
            "link_label": "Shop Style",
            "link": "shopify://collections/feature-products"
          }
        }
      },
      "block_order": [
        "col1",
        "col2",
        "col3"
      ],
      "settings": {
        "title": "The Vain Edit",
        "heading_size": "h2",
        "image_width": "full",
        "image_ratio": "adapt",
        "columns_desktop": 3,
        "column_alignment": "left",
        "background_style": "primary",
        "button_label": "Follow @VainShades",
        "button_link": "https://www.instagram.com/",
        "color_scheme": "scheme-2",
        "columns_mobile": "1",
        "swipe_on_mobile": false,
        "padding_top": 72,
        "padding_bottom": 72
      }
    },
    "newsletter": {
      "type": "email-signup-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Join the Inner Circle",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "paragraph",
          "settings": {
            "text": "Be first to see new drops, exclusive offers, and editorial lookbooks."
          }
        }
      },
      "block_order": [
        "heading",
        "text"
      ],
      "settings": {
        "color_scheme": "scheme-3",
        "full_width": true,
        "padding_top": 80,
        "padding_bottom": 80
      }
    }
  },
  "order": [
    "hero_banner",
    "featured_products",
    "brand_statement",
    "collection_showcase",
    "about_teaser",
    "instagram_showcase",
    "newsletter"
