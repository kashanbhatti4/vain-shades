{% comment %}
  Renders cart drawer — Vain Shades custom build.

  Rebuilt from scratch with a flexbox layout (no Dawn table/grid) so item
  rows never collapse on narrow mobile widths. All Shopify/Dawn JS hooks are
  preserved: cart-drawer / cart-drawer-items custom elements, #CartDrawer,
  #CartDrawer-Overlay, .drawer__inner, .js-contents, quantity-input,
  cart-remove-button, #Drawer-quantity-{index}, #CartDrawer-Item-{index},
  .cart-item__name, .cart-item__error-text, .loading__spinner, .cart-drawer__footer.

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner{% if cart == empty %} is-empty{% endif %}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- comment -%} ── HEADER ──────────────────────────────────────── {%- endcomment -%}
      <div class="drawer__header vs-cart__header">
        <h2 class="drawer__heading vs-cart__title">{{ 'sections.cart.title' | t }}</h2>
        <button
          class="drawer__close vs-cart__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">
            {{- 'icon-close.svg' | inline_asset_content -}}
          </span>
        </button>
      </div>

      {%- comment -%} ── EMPTY STATE ─────────────────────────────────── {%- endcomment -%}
      {%- if cart == empty -%}
        <div class="drawer__inner-empty vs-cart__empty">
          <p class="vs-cart__empty-text">{{ 'sections.cart.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="vs-btn vs-cart__empty-cta">
            {{ 'general.continue_shopping' | t }}
          </a>

          {%- if shop.customer_accounts_enabled and customer == null -%}
            <p class="vs-cart__login-title">{{ 'sections.cart.login.title' | t }}</p>
            <p class="vs-cart__login-paragraph">
              {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} ── ITEMS ───────────────────────────────────────── {%- endcomment -%}
      <cart-drawer-items class="vs-cart__items{% if cart == empty %} is-empty{% endif %}">
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="js-contents vs-cart__list">
            {%- if cart != empty -%}
              {%- for item in cart.items -%}
                <div
                  id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                  class="cart-item vs-ci{% if item.parent_relationship.parent != null %} vs-ci--nested{% endif %}"
                >
                  {%- comment -%} Image {%- endcomment -%}
                  <a
                    href="{{ item.url }}"
                    class="vs-ci__media"
                    tabindex="-1"
                    {% if item.image == nil %}aria-hidden="true"{% endif %}
                  >
                    {% if item.image %}
                      <img
                        class="cart-item__image vs-ci__image"
                        src="{{ item.image | image_url: width: 300 }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                        width="150"
                        height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                      >
                    {% endif %}
                  </a>

                  {%- comment -%} Body {%- endcomment -%}
                  <div class="vs-ci__body">
                    {%- render 'loading-spinner' -%}

                    <div class="vs-ci__top">
                      <div class="vs-ci__titles">
                        {%- if settings.show_vendor -%}
                          <p class="vs-ci__vendor">{{ item.product.vendor }}</p>
                        {%- endif -%}

                        <a href="{{ item.url }}" class="cart-item__name vs-ci__name">
                          {{- item.product.title | escape -}}
                        </a>

                        {%- if item.product.has_only_default_variant == false
                          or item.properties.size != 0
                          or item.selling_plan_allocation != null
                        -%}
                          <dl class="vs-ci__options">
                            {%- if item.product.has_only_default_variant == false -%}
                              {%- for option in item.options_with_values -%}
                                <div class="vs-ci__option">
                                  <dt>{{ option.name }}:</dt>
                                  <dd>{{ option.value -}}{%- unless forloop.last %}, {% endunless %}</dd>
                                </div>
                              {%- endfor -%}
                            {%- endif -%}

                            {%- for property in item.properties -%}
                              {%- assign property_first_char = property.first | slice: 0 -%}
                              {%- if property.last != blank and property_first_char != '_' -%}
                                <div class="vs-ci__option">
                                  <dt>{{ property.first }}:</dt>
                                  <dd>
                                    {%- if property.last contains '/uploads/' -%}
                                      <a href="{{ property.last }}" class="link" target="_blank">
                                        {{ property.last | split: '/' | last }}
                                      </a>
                                    {%- else -%}
                                      {{ property.last }}
                                    {%- endif -%}
                                  </dd>
                                </div>
                              {%- endif -%}
                            {%- endfor -%}
                          </dl>

                          {%- if item.selling_plan_allocation.selling_plan.name -%}
                            <p class="vs-ci__option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}
                        {%- endif -%}

                        <ul class="vs-ci__discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                          {%- for discount in item.line_level_discount_allocations -%}
                            <li class="vs-ci__discount">
                              {{- 'icon-discount.svg' | inline_asset_content -}}
                              {{ discount.discount_application.title }}
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>

                      {%- comment -%} Unit / line price {%- endcomment -%}
                      <div class="vs-ci__price">
                        {%- if item.original_price != item.final_price -%}
                          <s class="vs-ci__price-was">{{ item.original_price | money }}</s>
                          <span class="vs-ci__price-now">{{ item.final_price | money }}</span>
                        {%- else -%}
                          <span class="vs-ci__price-now">{{ item.original_price | money }}</span>
                        {%- endif -%}
                        {%- if item.variant.available and item.unit_price_measurement -%}
                          {% render 'unit-price', price: item.unit_price, measurement: item.unit_price_measurement %}
                        {%- endif -%}
                      </div>
                    </div>

                    {%- comment -%} Quantity + remove {%- endcomment -%}
                    <div class="vs-ci__bottom">
                      <quantity-input class="quantity cart-quantity vs-ci__qty">
                        <button
                          class="quantity__button"
                          name="minus"
                          type="button"
                          {% if item.instructions and item.instructions.can_update_quantity == false %}disabled{% endif %}
                        >
                          <span class="visually-hidden">
                            {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                          </span>
                          <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                        </button>
                        <input
                          class="quantity__input"
                          type="number"
                          data-quantity-variant-id="{{ item.variant.id }}"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          {% # theme-check-disable %}
                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                          min="0"
                          data-min="{{ item.variant.quantity_rule.min }}"
                          {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                          step="{{ item.variant.quantity_rule.increment }}"
                          {% # theme-check-enable %}
                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                          id="Drawer-quantity-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                          {% if item.instructions and item.instructions.can_update_quantity == false %}disabled{% endif %}
                        >
                        <button
                          class="quantity__button"
                          name="plus"
                          type="button"
                          {% if item.instructions and item.instructions.can_update_quantity == false %}disabled{% endif %}
                        >
                          <span class="visually-hidden">
                            {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                          </span>
                          <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                        </button>
                      </quantity-input>

                      <cart-remove-button
                        id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                        data-index="{{ item.index | plus: 1 }}"
                        class="vs-ci__remove"
                      >
                        <button
                          type="button"
                          class="vs-ci__remove-btn"
                          aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                          data-variant-id="{{ item.variant.id }}"
                          {% if item.instructions and item.instructions.can_remove == false %}class="hidden"{% endif %}
                        >
                          <span class="svg-wrapper">{{- 'icon-remove.svg' | inline_asset_content -}}</span>
                        </button>
                      </cart-remove-button>
                    </div>

                    <div
                      id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                      class="cart-item__error vs-ci__error"
                      role="alert"
                    >
                      <small class="cart-item__error-text"></small>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}

            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
              {{ 'accessibility.loading' | t }}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {%- comment -%} ── FOOTER ──────────────────────────────────────── {%- endcomment -%}
      {%- if cart != empty -%}
        <div class="cart-drawer__footer vs-cart__footer" {{ block.shopify_attributes }}>
          {%- if settings.show_cart_note -%}
            <details class="vs-cart__note-details" id="Details-CartDrawer">
              <summary class="vs-cart__note-summary">
                <span>{{ 'sections.cart.note' | t }}</span>
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </summary>
              <cart-note class="cart__note field">
                <label class="visually-hidden" for="CartDrawer-Note">{{ 'sections.cart.note' | t }}</label>
                <textarea
                  id="CartDrawer-Note"
                  class="text-area field__input vs-cart__note-input"
                  name="note"
                  placeholder="{{ 'sections.cart.note' | t }}"
                >{{ cart.note }}</textarea>
              </cart-note>
            </details>
          {%- endif -%}

          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <ul class="vs-cart__discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
              {%- for discount in cart.cart_level_discount_applications -%}
                <li class="vs-ci__discount">
                  {{- 'icon-discount.svg' | inline_asset_content -}}
                  {{ discount.title | escape }} (-{{ discount.total_allocated_amount | money }})
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <div class="vs-cart__totals" role="status">
            <span class="vs-cart__totals-label">{{ 'sections.cart.estimated_total' | t }}</span>
            <span class="vs-cart__totals-value">{{ cart.total_price | money_with_currency }}</span>
          </div>

          <p class="vs-cart__tax">
            {%- if cart.taxes_included -%}
              {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t | default: 'Taxes, discounts and shipping calculated at checkout.' }}
            {%- else -%}
              Taxes, discounts and shipping calculated at checkout.
            {%- endif -%}
          </p>

          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="vs-cart__checkout"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}disabled{% endif %}
          >
            {{ 'sections.cart.checkout' | t }}
          </button>
        </div>
      {%- else -%}
        {%- comment -%} keep an element present so onCartUpdate's replaceWith target exists {%- endcomment -%}
        <div class="cart-drawer__footer vs-cart__footer is-empty"></div>
      {%- endif -%}
    </div>
  </div>
</cart-drawer>
