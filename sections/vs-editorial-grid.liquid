<div class="vs-editorial-grid color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.subtext != blank -%}
      <div class="vs-editorial-grid__header">
        {%- if section.settings.title != blank -%}
          <h2 class="vs-editorial-grid__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="vs-editorial-grid__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
    
    <div class="vs-editorial-grid__container">
      {%- for block in section.blocks -%}
        <div class="vs-editorial-grid__card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" class="vs-editorial-grid__link">
            <div class="vs-editorial-grid__image-wrapper">
              {%- if block.settings.image != blank -%}
                <img 
                  src="{{ block.settings.image | image_url: width: 800 }}" 
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="100%"
                  height="100%"
                  class="vs-editorial-grid__image"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <div class="vs-editorial-grid__overlay"></div>
            </div>
            
            <div class="vs-editorial-grid__content">
              {%- if block.settings.subtitle != blank -%}
                <span class="vs-editorial-grid__card-subtitle vs-momo">{{ block.settings.subtitle }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="vs-editorial-grid__card-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.link_label != blank -%}
                <span class="vs-editorial-grid__card-cta">
                  {{ block.settings.link_label }}
                  <span class="vs-editorial-grid__arrow">→</span>
                </span>
              {%- endif -%}
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Editorial Category Grid",
  "tag": "section",
  "class": "section-vs-editorial-grid",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "The Vain Edit",
      "label": "Section Title"
    },
    {
      "type": "text",
      "id": "subtext",
      "default": "Explore our curated statements. Crafted for the bold, designed for the spotlight.",
      "label": "Section Subtext"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" }
      ],
      "default": "scheme-1",
      "label": "Color Scheme"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Category Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "default": "SHARP & BOLD",
          "label": "Card Subtitle"
        },
        {
          "type": "text",
          "id": "title",
          "default": "The Cat-Eye",
          "label": "Card Title"
        },
        {
          "type": "text",
          "id": "link_label",
          "default": "Explore Style",
          "label": "CTA Link Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "CTA Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Category Grid",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "title": "Day Dreamer",
            "subtitle": "OVERSIZED LUXURY"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Soho",
            "subtitle": "STREET-READY EDITORIAL"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Super Cats",
            "subtitle": "CAT-EYE REIMAGINED"
          }
        }
      ]
    }
  ]
}
{% endschema %}
