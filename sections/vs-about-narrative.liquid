<div class="vs-about-narrative">
  <div class="page-width">
    <div class="vs-about-narrative__grid">
      <div class="vs-about-narrative__left">
        <div class="vs-about-narrative__line"></div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="vs-about-narrative__eyebrow vs-momo">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.quote != blank -%}
          <h2 class="vs-about-narrative__quote">{{ section.settings.quote }}</h2>
        {%- endif -%}
      </div>
      <div class="vs-about-narrative__right">
        {%- if section.settings.body_text != blank -%}
          <div class="vs-about-narrative__body rte">
            {{ section.settings.body_text }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Brand Narrative",
  "tag": "section",
  "class": "section-vs-about-narrative",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "default": "ESTABLISHED IN MIAMI",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "quote",
      "default": "Designed to command attention, crafted for the spotlight.",
      "label": "Focus Quote/Headline"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "default": "<p>Vain Shades was created for those who do not follow trends, but establish them. Our frames are conceived in Miami, Florida, inspired by the city’s vibrant culture, luxury, and artistic energy. We believe that eyewear is not just an accessory—it is a statement of identity.</p><p>Every frame is handmade with zero compromises. We source our acetate from the finest eco-conscious manufacturers in Italy, polish each sheet by hand for over 72 hours, and integrate custom gold hardware hinges. The result is premium luxury comfort that stands out, not fits in.</p>",
      "label": "Detailed Narrative Text"
    }
  ],
  "presets": [
    {
      "name": "About Brand Narrative"
    }
  ]
}
{% endschema %}
