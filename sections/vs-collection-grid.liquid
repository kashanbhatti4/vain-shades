{%- paginate collection.products by section.settings.products_per_page -%}
  <div class="vs-collection-grid color-{{ section.settings.color_scheme }}">
    
    <!-- Collection Header -->
    <div class="vs-collection-grid__header page-width">
      <span class="vs-collection-grid__eyebrow vs-momo">COLLECTION</span>
      <h1 class="vs-collection-grid__title">{{ collection.title }}</h1>
      <span class="vs-collection-grid__count">{{ 'templates.collection.products_count' | t: count: collection.products_count }}</span>
      {%- if collection.description != blank -%}
        <div class="vs-collection-grid__description rte">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </div>

    <!-- Collection Toolbar -->
    <div class="vs-collection-grid__toolbar page-width">
      <div class="vs-collection-grid__toolbar-inner">
        <div class="vs-collection-grid__sort">
          <label for="SortBy" class="vs-collection-grid__sort-label">SORT BY:</label>
          <select name="sort_by" id="SortBy" class="vs-collection-grid__sort-select" aria-describedby="a11y-refresh-page-message">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected="selected"{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="page-width">
      <div id="ProductGridContainer">
        {%- if collection.products.size == 0 -%}
          <div class="vs-collection-grid__empty">
            <h2 class="vs-collection-grid__empty-title">No products found</h2>
            <p>Try clearing filters or checking back later.</p>
          </div>
        {%- else -%}
          <div 
            id="product-grid" 
            data-id="{{ section.id }}" 
            class="vs-collection-grid__grid columns-{{ section.settings.columns_desktop }}"
          >
            {%- for product in collection.products -%}
              {%- assign lazy_load = false -%}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              {%- assign product_form_id = 'quick-add-' | append: section.id | append: product.id -%}
              
              <div class="vs-product-card">
                <div class="vs-product-card__image-wrapper">
                  <a href="{{ product.url }}" class="vs-product-card__link" aria-label="{{ product.title | escape }}">
                    {%- if product.featured_media != blank -%}
                      <img 
                        src="{{ product.featured_media | image_url: width: 600 }}" 
                        alt="{{ product.featured_media.alt | escape }}"
                        loading="{% if lazy_load %}lazy{% else %}eager{% endif %}"
                        width="100%"
                        height="100%"
                        class="vs-product-card__image {% if product.media[1] != blank and section.settings.show_secondary_image %}vs-product-card__image--primary{% endif %}"
                      >
                      {%- if product.media[1] != blank and section.settings.show_secondary_image -%}
                        <img 
                          src="{{ product.media[1] | image_url: width: 600 }}" 
                          alt="{{ product.media[1].alt | escape }}"
                          loading="lazy"
                          width="100%"
                          height="100%"
                          class="vs-product-card__image vs-product-card__image--secondary"
                        >
                      {%- endif -%}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </a>
                  
                  {%- if product.compare_at_price > product.price -%}
                    <span class="vs-product-card__badge vs-product-card__badge--sale">SALE</span>
                  {%- elsif product.available == false -%}
                    <span class="vs-product-card__badge vs-product-card__badge--sold-out">SOLD OUT</span>
                  {%- endif -%}
                </div>
                
                <div class="vs-product-card__details">
                  <div class="vs-product-card__meta-row">
                    <span class="vs-product-card__type">
                      {%- if product.type != blank -%}
                        {{ product.type | uppercase }}
                      {%- else -%}
                        LUXURY SHADES
                      {%- endif -%}
                    </span>
                    
                    {%- for option in product.options_with_values -%}
                      {%- assign option_name_lower = option.name | downcase -%}
                      {%- if option_name_lower == 'color' or option_name_lower == 'colour' -%}
                        <div class="vs-product-card__swatches" aria-label="Available Colors">
                          {%- for value in option.values limit: 3 -%}
                            {%- assign swatch_color = value | split: ' ' | last | handle -%}
                            <span 
                              class="vs-product-card__swatch" 
                              style="background-color: {{ swatch_color }};" 
                              title="{{ value | escape }}"
                            ></span>
                          {%- endfor -%}
                          {%- if option.values.size > 3 -%}
                            <span class="vs-product-card__swatches-more">+{{ option.values.size | minus: 3 }}</span>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  
                  <h3 class="vs-product-card__title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>
                  
                  <div class="vs-product-card__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="vs-product-card__price--compare">{{ product.compare_at_price | money }}</span>
                      <span class="vs-product-card__price--sale">{{ product.price | money }}</span>
                    {%- else -%}
                      <span class="vs-product-card__price--regular">{{ product.price | money }}</span>
                    {%- endif -%}
                  </div>
                  
                  {%- if product.available -%}
                    <div class="vs-product-card__actions">
                      {%- form 'product', product, id: product_form_id, class: 'form vs-product-card__form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        <button type="submit" name="add" class="vs-product-card__btn-outline">
                          ADD TO CART
                        </button>
                      {%- endform -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Pagination -->
    {%- if paginate.pages > 1 -%}
      <div class="vs-collection-grid__pagination page-width">
        <nav class="vs-pagination" role="navigation" aria-label="Pagination">
          <ul class="vs-pagination__list" role="list">
            {%- if paginate.previous -%}
              <li>
                <a href="{{ paginate.previous.url }}" class="vs-pagination__item vs-pagination__item--prev" aria-label="Previous page">
                  ←
                </a>
              </li>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              <li>
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="vs-pagination__item" aria-label="Page {{ part.title }}">
                    {{ part.title }}
                  </a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span class="vs-pagination__item vs-pagination__item--current" aria-current="page" aria-label="Page {{ part.title }}">
                      {{ part.title }}
                    </span>
                  {%- else -%}
                    <span class="vs-pagination__item vs-pagination__item--gap">
                      {{ part.title }}
                    </span>
                  {%- endif -%}
                {%- endif -%}
              </li>
            {%- endfor -%}

            {%- if paginate.next -%}
              <li>
                <a href="{{ paginate.next.url }}" class="vs-pagination__item vs-pagination__item--next" aria-label="Next page">
                  →
                </a>
              </li>
            {%- endif -%}
          </ul>
        </nav>
      </div>
    {%- endif -%}

  </div>
{%- endpaginate -%}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sortSelect = document.querySelector('.vs-collection-grid__sort-select');
    if (sortSelect) {
      sortSelect.addEventListener('change', (event) => {
        const value = event.target.value;
        const searchParams = new URLSearchParams(window.location.search);
        searchParams.set('sort_by', value);
        window.location.search = searchParams.toString();
      });
    }
  });
</script>

{% schema %}
{
  "name": "Luxury Collection Grid",
  "tag": "section",
  "class": "section-vs-collection-grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "Products per Page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns on Desktop"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show Secondary Image on Hover"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" }
      ],
      "default": "scheme-1",
      "label": "Color Scheme"
    }
  ],
  "presets": [
    {
      "name": "Luxury Collection Grid"
    }
  ]
}
{% endschema %}
