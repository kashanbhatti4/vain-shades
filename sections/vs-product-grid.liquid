<div class="vs-product-grid color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.subtext != blank -%}
      <div class="vs-product-grid__header">
        {%- if section.settings.title != blank -%}
          <h2 class="vs-product-grid__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="vs-product-grid__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
    
    <div class="vs-product-grid__container columns-{{ section.settings.columns_desktop }}">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- assign limit = section.settings.products_to_show -%}
      
      {%- if collection != blank and collection.all_products_count > 0 -%}
        {%- for product in collection.products limit: limit -%}
          {%- assign product_form_id = 'quick-add-' | append: section.id | append: product.id -%}
          <div class="vs-product-card">
            <div class="vs-product-card__image-wrapper">
              <a href="{{ product.url }}" class="vs-product-card__link">
                {%- if product.featured_media != blank -%}
                  <img 
                    src="{{ product.featured_media | image_url: width: 600 }}" 
                    alt="{{ product.featured_media.alt | escape }}"
                    loading="lazy"
                    width="100%"
                    height="100%"
                    class="vs-product-card__image {% if product.media[1] != blank and section.settings.show_secondary_image %}vs-product-card__image--primary{% endif %}"
                  >
                  {%- if product.media[1] != blank and section.settings.show_secondary_image -%}
                    <img 
                      src="{{ product.media[1] | image_url: width: 600 }}" 
                      alt="{{ product.media[1].alt | escape }}"
                      loading="lazy"
                      width="100%"
                      height="100%"
                      class="vs-product-card__image vs-product-card__image--secondary"
                    >
                  {%- endif -%}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>
              
              {%- if product.compare_at_price > product.price -%}
                <span class="vs-product-card__badge vs-product-card__badge--sale">SALE</span>
              {%- elsif product.available == false -%}
                <span class="vs-product-card__badge vs-product-card__badge--sold-out">SOLD OUT</span>
              {%- endif -%}

              {%- if product.available -%}
                <div class="vs-product-card__quick-add">
                  {%- form 'product', product, id: product_form_id, class: 'form vs-product-card__form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <button type="submit" name="add" class="vs-product-card__btn" aria-haspopup="dialog">
                      QUICK ADD +
                    </button>
                  {%- endform -%}
                </div>
              {%- endif -%}
            </div>
            
            <div class="vs-product-card__details">
              <h3 class="vs-product-card__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <div class="vs-product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="vs-product-card__price--compare">{{ product.compare_at_price | money }}</span>
                  <span class="vs-product-card__price--sale">{{ product.price | money }}</span>
                {%- else -%}
                  <span class="vs-product-card__price--regular">{{ product.price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <div class="vs-product-card">
            <div class="vs-product-card__image-wrapper">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="vs-product-card__details">
              <h3 class="vs-product-card__title">Sample Sunglasses</h3>
              <div class="vs-product-card__price">
                <span class="vs-product-card__price--regular">$120.00</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Boutique Product Grid",
  "tag": "section",
  "class": "section-vs-product-grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Featured Collection",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subtext",
      "default": "Elevate your look with our most wanted designs.",
      "label": "Subtext"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to Show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Number of Columns on Desktop"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show Secondary Image on Hover"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" }
      ],
      "default": "scheme-1",
      "label": "Color Scheme"
    }
  ],
  "presets": [
    {
      "name": "Boutique Product Grid"
    }
  ]
}
{% endschema %}
